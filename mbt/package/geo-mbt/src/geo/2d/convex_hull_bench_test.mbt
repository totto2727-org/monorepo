// Benchmarks for convex_hull.mbt.

///|
test "bench: convex_hull n=50" (b : @bench.T) {
  // Random-looking but deterministic coords
  let mp = @type.MultiPoint::from_tuples([
    (1.0, 2.0),
    (3.5, -1.2),
    (5.0, 5.0),
    (-1.0, 2.0),
    (10.0, 10.0),
    (-5.0, -5.0),
    (8.0, 2.0),
    (3.0, 8.0),
    (4.5, 3.5),
    (-2.0, 7.0),
    (6.0, -3.0),
    (9.0, 1.5),
    (2.0, -4.5),
    (7.5, 8.5),
    (0.5, 9.5),
    (1.5, 1.5),
    (4.0, 4.0),
    (-3.0, -1.0),
    (8.0, -2.0),
    (5.5, 6.5),
    (1.0, -3.0),
    (3.5, 7.5),
    (-1.5, 5.5),
    (10.5, 5.0),
    (4.0, -1.5),
    (-4.0, 3.0),
    (6.5, 4.5),
    (2.5, 9.0),
    (8.5, 7.0),
    (0.0, -4.0),
    (-2.5, -3.5),
    (5.5, 1.0),
    (3.0, 3.0),
    (7.0, 7.0),
    (1.0, 5.0),
    (9.5, 3.5),
    (-3.5, 6.5),
    (4.5, 9.5),
    (6.0, 0.5),
    (2.0, 2.5),
    (-1.0, -2.0),
    (8.5, 4.5),
    (3.5, 5.5),
    (-4.5, 1.5),
    (5.0, -3.5),
    (7.5, 2.5),
    (0.5, 6.0),
    (-2.0, 4.5),
    (4.0, 8.0),
    (10.0, 0.0),
  ])
  b.bench(fn() { b.keep(convex_hull_of_multi_point(mp)) })
}
