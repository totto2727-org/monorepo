{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "commitMessagePrefix": "feat(deps): ",
  "extends": ["config:recommended", ":timezone(Asia/Tokyo)"],
  "ignoreDeps": ["@totto2727/fp"],
  "labels": ["renovate", "deps"],
  "schedule": ["0 0 * * 6"],
  "packageRules": [
    {
      "groupName": "Updates major",
      "matchUpdateTypes": ["major"],
      "minimumReleaseAge": "3 days"
    },
    {
      "groupName": "Updates minor",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.default"],
      "groupName": "pnpm.catalog.default updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.storybook"],
      "groupName": "pnpm.catalog.storybook updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.effect"],
      "groupName": "pnpm.catalog.effect updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.hono"],
      "groupName": "pnpm.catalog.hono updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.vite"],
      "groupName": "pnpm.catalog.vite updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.build"],
      "groupName": "pnpm.catalog.build updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.auth"],
      "groupName": "pnpm.catalog.auth updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "automerge": true,
      "matchDepTypes": ["pnpm.catalog.cloudflare"],
      "groupName": "pnpm.catalog.cloudflare updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.dev"],
      "groupName": "pnpm.catalog.dev updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.graphql"],
      "groupName": "pnpm.catalog.graphql updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "automerge": true,
      "matchDepTypes": ["pnpm.catalog.lint"],
      "groupName": "pnpm.catalog.lint updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "automerge": true,
      "matchDepTypes": ["pnpm.catalog.pulumi"],
      "groupName": "pnpm.catalog.pulumi updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.react"],
      "groupName": "pnpm.catalog.react updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.ui"],
      "groupName": "pnpm.catalog.ui updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.i18n"],
      "groupName": "pnpm.catalog.i18n updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "matchDepTypes": ["pnpm.catalog.database"],
      "groupName": "pnpm.catalog.database updates",
      "matchUpdateTypes": ["minor"],
      "minimumReleaseAge": "3 days"
    },
    {
      "automerge": true,
      "groupName": "Patch updates",
      "matchUpdateTypes": ["patch", "digest", "bump", "lockFileMaintenance"],
      "minimumReleaseAge": "3 days"
    },
    {
      "automerge": true,
      "groupName": "TypeScript native preview updates",
      "matchPackageNames": ["@typescript/native-preview"],
      "minimumReleaseAge": "3 days"
    }
  ]
}
